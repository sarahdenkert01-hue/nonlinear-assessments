generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Sprint 1 introduced the durable spine: Client -> AssessmentEpisode -> ModuleInstance -> Response.
// Episodes may contain multiple client-facing modules (screener + explorations). The clinician
// workflow status (DRAFT/SUBMITTED/REVIEWED) still lives on the episode. Screener submission
// moves the episode out of DRAFT so findings/domains unlock; other modules track their own
// ModuleStatus independently.

enum SessionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum ModuleAudience {
  CLIENT
  CLINICIAN
}

enum ModuleStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

// Who caused an audited action. Kept as an enum so future AI/system actors are explicit.
enum AuthorType {
  CLIENT
  CLINICIAN
  SYSTEM
}

// Lifecycle of a clinical finding. PROPOSED/ACCEPTED/EDITED are included in the report;
// EXCLUDED is kept for the record but left out. A finding is never auto-"confirmed".
enum FindingStatus {
  PROPOSED
  ACCEPTED
  EDITED
  EXCLUDED
}

// Where a finding originated. The algorithm only ever proposes; clinicians own the rest.
enum FindingSource {
  ALGORITHM
  CLINICIAN
}

// Clinical confidence is clinician-owned. Findings start with NO confidence set (null);
// the algorithm never implies a confidence level.
enum Confidence {
  LOW
  MODERATE
  HIGH
}

enum EvidenceSourceType {
  CLIENT_SELF_REPORT
  CLINICIAN_INTERVIEW
  CLINICIAN_OBSERVATION
  COLLATERAL
  STRUCTURED_MEASURE
  MANUAL_NOTE
  FINDING
}

model Client {
  id          String              @id @default(cuid())
  clinicianId String
  displayName String
  email       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  episodes    AssessmentEpisode[]

  @@index([clinicianId])
}

// An evaluation case for one client. Holds clinician review state and (later) many modules.
model AssessmentEpisode {
  id                String           @id @default(cuid())
  clinicianId       String?
  clientId          String?
  client            Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  status            SessionStatus    @default(DRAFT)
  clientName        String?
  // Clinician review state. Report fields are replaced by sectioned reports in a later sprint.
  overrides         Json?
  clinicianNotes    String?
  reportDraft       String?
  reportFinal       String?
  reportGeneratedAt DateTime?
  reportFinalizedAt DateTime?
  notifiedAt        DateTime?
  submittedAt       DateTime?
  reviewedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  modules           ModuleInstance[]
  findings          Finding[]
  domainReviews     DomainReview[]
  events            AuditEvent[]

  @@index([clinicianId])
  @@index([clientId])
  @@index([status])
}

// One administration of one instrument within an episode. Client-facing modules carry the
// delivery token + consent; clinician-facing modules (added later) will leave those null.
model ModuleInstance {
  id                String            @id @default(cuid())
  episodeId         String
  episode           AssessmentEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  moduleKey         String
  moduleVersion     String
  audience          ModuleAudience    @default(CLIENT)
  status            ModuleStatus      @default(NOT_STARTED)
  // Client-facing delivery (null for clinician-administered modules).
  token             String?           @unique
  tokenExpiresAt    DateTime?
  revokedAt         DateTime?
  consentAcceptedAt DateTime?
  submittedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  responses         Response[]
  findings          Finding[]
  events            AuditEvent[]

  @@index([episodeId])
  @@index([moduleKey])
  @@index([status])
}

// One answered item within a module. Normalized so findings can link to specific evidence later.
model Response {
  id               String         @id @default(cuid())
  moduleInstanceId String
  moduleInstance   ModuleInstance @relation(fields: [moduleInstanceId], references: [id], onDelete: Cascade)
  itemId           String
  value            Json
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  evidence         FindingEvidence[]

  @@unique([moduleInstanceId, itemId])
  @@index([moduleInstanceId])
}

model AuditEvent {
  id               String            @id @default(cuid())
  episodeId        String
  episode          AssessmentEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  moduleInstanceId String?
  moduleInstance   ModuleInstance?   @relation(fields: [moduleInstanceId], references: [id], onDelete: SetNull)
  actorType        String
  actorId          String?
  action           String
  metadata         Json?
  createdAt        DateTime          @default(now())

  @@index([episodeId])
  @@index([createdAt])
}

// An interpreted clinical signal for an episode (Sprint 2: one per scored theme). The algorithm
// proposes findings; the clinician owns status, confidence, and alternative explanations. Each
// finding links to the exact responses that support it via FindingEvidence.
model Finding {
  id                     String            @id @default(cuid())
  episodeId              String
  episode                AssessmentEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  moduleInstanceId       String?
  moduleInstance         ModuleInstance?   @relation(fields: [moduleInstanceId], references: [id], onDelete: SetNull)
  code                   String
  label                  String
  category               String?
  status                 FindingStatus     @default(PROPOSED)
  source                 FindingSource     @default(ALGORITHM)
  // Clinician-owned; null until a clinician sets it. The algorithm never fills this in.
  confidence             Confidence?
  alternativeExplanations String[]
  rationale              String?
  hits                   Int               @default(0)
  total                  Int               @default(0)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  evidence               FindingEvidence[]

  @@index([episodeId])
  @@index([status])
}

// Links a finding to a specific response (the endorsed item behind it). itemId is kept alongside
// responseId so the evidence trail survives even if a response row is later removed.
model FindingEvidence {
  id         String    @id @default(cuid())
  findingId  String
  finding    Finding   @relation(fields: [findingId], references: [id], onDelete: Cascade)
  responseId String?
  response   Response? @relation(fields: [responseId], references: [id], onDelete: SetNull)
  itemId     String?
  note       String?
  createdAt  DateTime  @default(now())

  @@index([findingId])
}

// Clinician-owned synthesis for one clinical domain within an episode. Aggregates confirmed
// findings and other evidence — never auto-filled by the algorithm.
model DomainReview {
  id                      String              @id @default(cuid())
  episodeId               String
  episode                 AssessmentEpisode   @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  domainId                String
  confidence              Confidence?
  alternativeExplanations String[]
  clinicalNotes           String?
  evidenceGapNotes        String?
  evidenceSummaryDraft    String?
  suggestedQuestionsDraft String?
  clinicalQuestionPrompts Json?
  clinicalFormulationDraft Json?
  summaryDraft            String?
  reviewedAt              DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  evidence                DomainEvidence[]

  @@unique([episodeId, domainId])
  @@index([episodeId])
}

// One traceable piece of evidence contributing to a domain review.
model DomainEvidence {
  id               String             @id @default(cuid())
  domainReviewId   String
  domainReview     DomainReview       @relation(fields: [domainReviewId], references: [id], onDelete: Cascade)
  sourceType       EvidenceSourceType
  findingId        String?
  responseId       String?
  moduleInstanceId String?
  itemId           String?
  excerpt          String?
  createdAt        DateTime           @default(now())

  @@unique([domainReviewId, findingId])
  @@index([domainReviewId])
}

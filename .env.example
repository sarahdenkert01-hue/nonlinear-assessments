# Database (PostgreSQL — Neon, Supabase, or local Docker)
# Example: postgresql://user:password@host/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Optional: customize auth URLs (defaults work for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Optional: LLM-assisted report drafting (server-side only)
# Without a key, reports use a structured template draft.
# Gemini (Google AI Studio): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite
# Anthropic (alternative): https://console.anthropic.com
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Force provider when both keys are set: gemini | anthropic | auto
# REPORT_LLM_PROVIDER=auto
# REPORT_USE_LLM=false
# REPORT_LLM_TIMEOUT_MS=30000
# REPORT_PROFILE=standard

# Submission notifications (optional)
# NOTIFY_EMAIL=you@clinic.com
# RESEND_API_KEY=
# NOTIFY_FROM=reports@yourdomain.com
# NEXT_PUBLIC_APP_URL=http://localhost:3000
